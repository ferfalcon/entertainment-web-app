---
import AppNav from '../components/navigation/AppNav.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
	title: string;
	heading?: string;
}

const { title, heading = title } = Astro.props;
---

<BaseLayout title={title}>
	<a class="skip-link visually-hidden" href="#main-content">Skip to main content</a>
	<div class="app-shell">
		<AppNav />
		<main id="main-content" class="app-shell__main" tabindex="-1" aria-labelledby="page-title">
			<h1 id="page-title" class="app-shell__title">{heading}</h1>
			<slot />
		</main>
	</div>
</BaseLayout>
