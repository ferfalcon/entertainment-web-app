---
import type { NavIconName } from '../../data/navigation';
import Icon from '../ui/Icon.astro';

interface Props {
	href: string;
	label: string;
	icon: NavIconName;
	isActive?: boolean;
}

const { href, label, icon, isActive = false } = Astro.props;
---

<a
	class:list={['nav-icon-link', { 'is-active': isActive }]}
	href={href}
	aria-label={label}
	aria-current={isActive ? 'page' : undefined}
>
	<Icon name={icon} />
</a>
